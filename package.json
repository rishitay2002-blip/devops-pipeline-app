{
  "name": "devops-pipeline-app",
  "version": "1.0.0",
  "description": "Sample Node.js REST API for SIT753 Jenkins DevOps Pipeline",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "build": "echo 'Build complete - version 1.0.0' && mkdir -p dist && cp -r src dist/",
    "test": "jest --coverage --coverageReporters=lcov --coverageReporters=text",
    "lint": "eslint src/ --ext .js"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
